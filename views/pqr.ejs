<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flipkart Checkout</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#f1f3f6;
}

/* NAVBAR */

.navbar{
    background:#2874f0;
    color:white;
    padding:15px 40px;
    display:flex;
    align-items:center;
    gap:15px;
    box-shadow:0 2px 5px rgba(0,0,0,0.1);
}

.navbar img{
    width:20px;
    height:50px;
}

.navbar h2{
    font-size:17px;
    margin-left: 10px;
}

/* MAIN CONTAINER */

.checkout-container{
    max-width:1100px;
    margin:30px auto;
    display:flex;
    gap:20px;
    flex-wrap:wrap;
}


.right{
    flex:1;
}

/* CARDS */

.card{
    background:white;
    border-radius:8px;
    padding:20px;
    box-shadow:0 2px 5px rgba(0,0,0,0.1);
}

.section-title{
    font-size:20px;
    font-weight:bold;
    margin-bottom:20px;
    color:#212121;
}

/* QR SECTION */

.qr-section{
    text-align:center;
}

.qr-section img{
    width:280px;
    height:280px;
    object-fit:cover;
    border:1px solid #ddd;
    padding:10px;
    border-radius:10px;
}

.qr-section p{
    margin-top:15px;
    color:#555;
    line-height:1.6;
}

/* PRICE DETAILS */

.price-row{
    display:flex;
    justify-content:space-between;
    margin-bottom:15px;
    font-size:16px;
}

.total{
    border-top:1px solid #ddd;
    padding-top:15px;
    margin-top:15px;
    font-size:20px;
    font-weight:bold;
}

.place-order{
    width:100%;
    margin-top:20px;
    background:#fb641b;
    color:white;
    border:none;
    padding:15px;
    border-radius:5px;
    font-size:18px;
    cursor:pointer;
}

.place-order:hover{
    background:#e85d0f;
}

.success-note{
    margin-top:15px;
    font-size:14px;
    color:#777;
    text-align:center;
}

@media(max-width:768px){

    .checkout-container{
        flex-direction:column;
        padding:0 15px;
    }

    .navbar{
        padding:15px;
    }

    .navbar img{
        width:90px;
    }

    .qr-section img{
        width:220px;
        height:220px;
    }
}

</style>

</head>

<body>

<!-- HEADER -->

<div class="navbar">
    <img src="/photoes/Logo.webp" alt="Flipkart Logo">
    <h2>Flipkart Checkout</h2>
</div>

<!-- CHECKOUT -->

<div class="checkout-container">

```
<!-- LEFT SECTION -->

<div class="left">

    <div class="card qr-section">

        <div class="section-title">
            Scan QR & Pay
        </div>

        <img src="/photoes/qr2.jpeg" alt="QR Code">

        <p>
            Scan this QR code using Google Pay,
            PhonePe, Paytm, BHIM or any UPI App.
        </p>

        <p>
            Amount To Pay: <strong>₹99</strong>
        </p>

    </div>

</div>

<!-- RIGHT SECTION -->

<div class="right">

    <div class="card">

        <div class="section-title">
            Price Details
        </div>

        <div class="price-row">
            <span>Product Price</span>
            <span>₹1099</span>
        </div>

        <div class="price-row">
            <span>Delivery Charge</span>
            <span style="color:green;">FREE</span>
        </div>

        <div class="price-row">
            <span>Discount</span>
            <span style="color:green;">- ₹1000</span>
        </div>

        <div class="price-row total">
            <span>Total Amount</span>
            <span>₹99</span>
        </div>

        <form action="/" method="get">

            <button class="place-order">
                I Have Paid
            </button>

        </form>

        <div class="success-note">
            Click only after completing payment.
        </div>

    </div>

</div>
```

</div>

</body>
</html>
